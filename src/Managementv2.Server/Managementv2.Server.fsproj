<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <DefaultItemExcludes>$(DefaultItemExcludes);operations/**/*</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="KeycloakRolesClaimsTransformation.fs" />
    <Compile Include="CustomOperationsConfig.fs" />
    <Compile Include="CustomOperationsStore.fs" />
    <Compile Include="PowerShellModulePath.fs" />
    <Compile Include="CodeExecution.fs" />
    <Compile Include="WeatherForecast.fs" />
    <Compile Include="Controllers/WeatherForecastController.fs" />
    <Compile Include="Controllers/CustomOperationsController.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Identity.Web" Version="4.13.2" />
    <PackageReference Include="Microsoft.PowerShell.SDK" Version="7.4.6" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Sokrates.PowerShell\Sokrates.PowerShell.fsproj" />
  </ItemGroup>

</Project>
